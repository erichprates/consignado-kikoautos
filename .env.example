# Template das variáveis de ambiente do RVops.
# Copie pra .env e preencha com valores reais — o .env está no .gitignore.
# Em produção, configure no painel da Netlify (Site settings → Environment variables).
# NUNCA commitar credenciais reais neste arquivo.

# Client ID do RVops (no painel, ou na URL do dashboard):
RVOPS_CLIENT_ID=seu-client-id-aqui

# API Key do RVops (Settings → API Keys):
RVOPS_API_KEY=sua-api-key-aqui

# Identificador desta LP no RVops. Esta é a LP de venda/consignação de CARRO,
# servida em https://vendaseucarro.kikoautos.com.
# Quando criar a LP de MOTO, será um deploy separado com vendasuamoto-kikoautos
# (ou similar). Nunca hardcodar no código — sempre lido do env.
RVOPS_LP_ORIGEM=vendaseucarro-kikoautos
